{
  "name": "eberron-calendar",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:roll20": "node build.mjs",
    "build:web": "tsc --noEmit && vite build",
    "build": "npm run build:roll20 && npm run build:web",
    "dev": "vite",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test --test-force-exit test/**/*.test.ts",
    "check": "npm run typecheck && npm test"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
