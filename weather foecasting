## Part 9: Forecast Lens Function (Pseudocode)

```typescript
function _forecastLens(
  rec: WeatherRecord,
  prevRec: WeatherRecord,
  tier: 'low' | 'medium' | 'high',
  quality: number,           // rank on the quality ladder
  zone: 'A' | 'B' | 'C' | 'D' | 'Ap' | 'Bp',  // current zone or tail tag
  playerPlanarReveals: PlanarRevealSet,
  manifestOverlays: ManifestOverlaySet
): ForecastValues {

  // High tier: exact truth, no lens
  if (tier === 'high') return rec.final;

  // 1. Decompose deltas per trait
  for each trait in [temp, wind, precip]:
    planarDelta[trait] = rec.overlay[trait] || 0
    manifestDelta[trait] = rec.manifest[trait] || 0
    knownPlanar[trait] = sum of overlay contributions from planes
                         the player has reveals for on this serial
    unknownPlanar[trait] = planarDelta[trait] - knownPlanar[trait]

  // 2. Regression target = previous day
  target[trait] = prevRec.final[trait]

  // 3. Compute regressable portion per trait
  // This is the part of the delta (from previous day) that the
  // forecaster can't explain
  regressable[trait] = rec.final[trait]
                       - knownPlanar[trait]
                       - manifestDelta[trait]
                       - target[trait]
  // (regressable includes naturalDelta + unknownPlanar, measured
  //  relative to previous day)

  // 4. Determine jitter level from zone/tier tables
  jitterLevel = lookupJitterLevel(tier, zone)
  // Returns: 0 (exact), 1 (wind only), 2 (wind+precip), 3 (all)

  // 5. Determine which traits to jitter (fixed order)
  affectedTraits = []
  if jitterLevel >= 1: affectedTraits.push('wind')
  if jitterLevel >= 2: affectedTraits.push('precip')
  if jitterLevel >= 3: affectedTraits.push('temp')

  // 6. Apply jitter to affected traits
  for each trait in affectedTraits:
    dayOverDayDelta = |rec.final[trait] - prevRec.final[trait]|
    // Determine direction die
    if dayOverDayDelta >= 2: directionDie = 10  // 1 on d10 = away
    else if dayOverDayDelta == 1: directionDie = 4  // 1 on d4 = away
    else: directionDie = 6  // 1-3 toward, 4-6 away (coin flip)

    seed = hash(rec.serial, zone, worldSeed, 'jitter', trait)
    directionRoll = seededDie(directionDie, seed)

    if directionDie == 6:
      goToward = (directionRoll <= 3)
    else:
      goToward = (directionRoll != 1)

    jitterMagnitude = 1  // always ±1 for jitter
    if goToward:
      // Push forecast toward previous day (reduce regressable)
      sign = -sign(regressable[trait])
    else:
      // Push forecast away from previous day
      sign = sign(regressable[trait]) || 1  // if 0, pick +1

    forecastDelta[trait] = regressable[trait] + (jitterMagnitude * sign)

  // Non-jittered traits pass through unchanged
  for each trait NOT in affectedTraits:
    forecastDelta[trait] = regressable[trait]

  // 7. Apply mask if it fires
  maskDie = lookupMaskDie(tier, zone)  // from the mask dice tables
  maskSeed = hash(rec.serial, zone, worldSeed, 'mask')
  maskRoll = seededDie(maskDie, maskSeed)

  if maskRoll == 1:
    // Find the trait with the biggest day-over-day shift
    // (wind breaks ties)
    dominantTrait = traitWithLargestDayOverDay(rec, prevRec)
    // Snap toward previous day's value ±1
    snapSeed = hash(rec.serial, worldSeed, 'mask-snap')
    forecastDelta[dominantTrait] = seededDie(2, snapSeed) == 1 ? +1 : -1
    // (This replaces the regressable portion with just ±1 from prev day,
    //  effectively predicting "same as yesterday" with slight variation)

  // 8. Reassemble forecast values
  for each trait:
    forecast[trait] = target[trait]
                      + knownPlanar[trait]
                      + manifestDelta[trait]
                      + forecastDelta[trait]

  // 9. Seasonal clamp (shifted by known effects)
  for each trait:
    effectiveMin = climate.month.min[trait]
                   + knownPlanar[trait]
                   + manifestDelta[trait]
    effectiveMax = climate.month.max[trait]
                   + knownPlanar[trait]
                   + manifestDelta[trait]
    forecast[trait] = clamp(forecast[trait], effectiveMin, effectiveMax)

  return forecast
}
```

